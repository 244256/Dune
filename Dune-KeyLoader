-- ── LOGIC ────────────────────────────────────────────────────────────────────
local busy = false

local function setStatus(msg, col)
    Status.Text       = msg
    Status.TextColor3 = col or SUB
end

Btn.MouseButton1Click:Connect(function()
    if busy then return end
    local key = Box.Text:match("^%s*(.-)%s*$")
    if key == "" then
        setStatus("⚠  Paste your key first.", Color3.fromRGB(220,140,40))
        return
    end
    busy = true
    Btn.Text = "CHECKING..."
    tw(Btn, {BackgroundColor3=GOLD_DIM}, .1)
    setStatus("Contacting KeyAuth...", Color3.fromRGB(155,142,108))

    local hwid = "none"
    pcall(function()
        hwid = tostring(game:GetService("RbxAnalyticsService"):GetClientId())
    end)

    local data = kReq(
        "type=license"
        .."&key="       .. HS:UrlEncode(key)
        .."&hwid="      .. HS:UrlEncode(hwid)
        .."&sessionid=" .. HS:UrlEncode(sessionID)
        .."&name="      .. HS:UrlEncode(Name)
        .."&ownerid="   .. HS:UrlEncode(OwnerID)
    )

    if data and data.success then
        setStatus("✓  Valid! Loading Dune V2...", GREEN)
        tw(Btn, {BackgroundColor3=Color3.fromRGB(55,170,75)}, .15)
        Btn.Text = "LOADING..."
        task.wait(1)
        SG:Destroy()
        local ok, res = pcall(request, {Url = SCRIPT_URL, Method = "GET"})
        if ok and res and res.StatusCode == 200 then
            local fn, err = loadstring(res.Body)
            if fn then fn()
            else warn("[Dune V2] loadstring error: " .. tostring(err)) end
        else
            warn("[Dune V2] Could not fetch script — check SCRIPT_URL")
        end
    else
        local msg = (data and data.message) or "Invalid or expired key."
        setStatus("✗  " .. msg, RED)
        tw(Btn, {BackgroundColor3=GOLD}, .15)
        Btn.Text = "ACTIVATE KEY"
        busy = false
    end
end)
