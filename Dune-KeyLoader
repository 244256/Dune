local function tw(obj, props, t)
    TS:Create(obj, TweenInfo.new(t or .14), props):Play()
end

local function kReq(body)
    local ok, res = pcall(request, {
        Url     = KeyAuthURL,
        Method  = "POST",
        Headers = {["Content-Type"] = "application/x-www-form-urlencoded"},
        Body    = body
    })
    if not ok or not res then return nil end
    local ok2, d = pcall(function() return HS:JSONDecode(res.Body) end)
    return ok2 and d or nil
end

local init = kReq(
    "type=init"
    .."&name="    .. HS:UrlEncode(Name)
    .."&ownerid=" .. HS:UrlEncode(OwnerID)
    .."&secret="  .. HS:UrlEncode(Secret)
    .."&ver="     .. HS:UrlEncode(Version)
)
if not init or not init.success then
    error("[Dune V2] KeyAuth init failed: " .. ((init and init.message) or "no response"))
end
sessionID = init.sessionid

